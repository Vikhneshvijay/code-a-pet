{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scratch-sb3-schema",
  "title": "Scratch 3.0 project.json",
  "description": "Schema for Scratch 3.0 SB3 project JSON file",
  "type": "object",
  "required": ["targets", "monitors", "extensions", "meta"],
  "additionalProperties": false,
  "properties": {
    "targets": {
      "type": "array",
      "description": "Array of target objects. targets[0] must be the Stage.",
      "minItems": 1,
      "items": { "$ref": "#/definitions/target" }
    },
    "monitors": {
      "type": "array",
      "description": "Array of stage monitors",
      "items": { "$ref": "#/definitions/monitor" }
    },
    "extensions": {
      "type": "array",
      "description": "Extension IDs used by the project",
      "items": {
        "type": "string",
        "enum": ["pen","wedo2","music","microbit","text2speech","translate","videoSensing","ev3","makeymakey","boost","gdxfor"]
      }
    },
    "meta": {
      "type": "object",
      "required": ["semver","vm","agent"],
      "additionalProperties": false,
      "properties": {
        "semver": { "type": "string", "const": "3.0.0" },
        "vm":     { "type": "string" },
        "agent":  { "type": "string" }
      }
    }
  },

  "definitions": {
    "target": {
      "type": "object",
      "required": ["isStage","name","variables","lists","broadcasts","blocks","comments","currentCostume","costumes","sounds","volume","layerOrder"],
      "properties": {
        "isStage":        { "type": "boolean" },
        "name":           { "type": "string" },
        "variables":      { "type": "object", "additionalProperties": { "$ref": "#/definitions/variable" } },
        "lists":          { "type": "object", "additionalProperties": { "$ref": "#/definitions/list" } },
        "broadcasts":     { "type": "object", "additionalProperties": { "type": "string" } },
        "blocks":         { "type": "object", "additionalProperties": { "$ref": "#/definitions/block" } },
        "comments":       { "type": "object", "additionalProperties": { "$ref": "#/definitions/comment" } },
        "currentCostume": { "type": "integer", "minimum": 0 },
        "costumes":       { "type": "array", "items": { "$ref": "#/definitions/costume" } },
        "sounds":         { "type": "array", "items": { "$ref": "#/definitions/sound" } },
        "volume":         { "type": "number", "minimum": 0, "maximum": 100 },
        "layerOrder":     { "type": "integer", "minimum": 0 },
        "tempo":               { "type": "number" },
        "videoTransparency":   { "type": "number", "minimum": 0, "maximum": 100 },
        "videoState":          { "type": "string", "enum": ["on","off","on-flipped"] },
        "textToSpeechLanguage":{ "type": ["string","null"] },
        "visible":        { "type": "boolean" },
        "x":              { "type": "number" },
        "y":              { "type": "number" },
        "size":           { "type": "number", "minimum": 0 },
        "direction":      { "type": "number" },
        "draggable":      { "type": "boolean" },
        "rotationStyle":  { "type": "string", "enum": ["all around","left-right","don't rotate"] }
      }
    },

    "variable": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": [
        { "type": "string", "description": "Variable name" },
        { "description": "Current value" },
        { "type": "boolean", "const": true, "description": "Cloud variable flag" }
      ]
    },

    "list": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": [
        { "type": "string", "description": "List name" },
        { "type": "array",  "description": "List contents" }
      ]
    },

    "block": {
      "oneOf": [
        { "$ref": "#/definitions/standardBlock" },
        { "$ref": "#/definitions/primitiveBlock" }
      ]
    },

    "standardBlock": {
      "type": "object",
      "required": ["opcode","next","parent","inputs","fields","shadow","topLevel"],
      "properties": {
        "opcode":   { "type": "string" },
        "next":     { "type": ["string","null"] },
        "parent":   { "type": ["string","null"] },
        "inputs":   { "type": "object" },
        "fields":   { "type": "object" },
        "shadow":   { "type": "boolean" },
        "topLevel": { "type": "boolean" },
        "x":        { "type": "number" },
        "y":        { "type": "number" },
        "comment":  { "type": "string" },
        "mutation": { "$ref": "#/definitions/mutation" }
      }
    },

    "primitiveBlock": {
      "type": "array",
      "minItems": 2,
      "items": [
        { "type": "integer", "minimum": 4, "maximum": 13, "description": "Primitive type code" }
      ]
    },

    "mutation": {
      "type": "object",
      "required": ["tagName","children"],
      "properties": {
        "tagName":          { "type": "string", "const": "mutation" },
        "children":         { "type": "array", "maxItems": 0 },
        "proccode":         { "type": "string" },
        "argumentids":      { "type": "string", "description": "JSON-encoded array of arg IDs" },
        "argumentnames":    { "type": "string", "description": "JSON-encoded array of arg names" },
        "argumentdefaults": { "type": "string", "description": "JSON-encoded array of arg defaults" },
        "warp":             { "type": ["boolean","string"] },
        "hasnext":          { "type": ["boolean","string"] }
      }
    },

    "comment": {
      "type": "object",
      "required": ["x","y","width","height","minimized","text"],
      "properties": {
        "blockId":   { "type": ["string","null"] },
        "x":         { "type": "number" },
        "y":         { "type": "number" },
        "width":     { "type": "number" },
        "height":    { "type": "number" },
        "minimized": { "type": "boolean" },
        "text":      { "type": "string" }
      }
    },

    "asset": {
      "type": "object",
      "required": ["assetId","name","md5ext","dataFormat"],
      "properties": {
        "assetId":    { "type": "string", "pattern": "^[0-9a-f]{32}$" },
        "name":       { "type": "string" },
        "md5ext":     { "type": "string" },
        "dataFormat": { "type": "string" }
      }
    },

    "costume": {
      "allOf": [
        { "$ref": "#/definitions/asset" },
        {
          "type": "object",
          "required": ["rotationCenterX","rotationCenterY"],
          "properties": {
            "bitmapResolution": { "type": "integer", "enum": [1,2] },
            "rotationCenterX":  { "type": "number" },
            "rotationCenterY":  { "type": "number" }
          }
        }
      ]
    },

    "sound": {
      "allOf": [
        { "$ref": "#/definitions/asset" },
        {
          "type": "object",
          "properties": {
            "rate":        { "type": "number" },
            "sampleCount": { "type": "integer" },
            "format":      { "type": "string" }
          }
        }
      ]
    },

    "monitor": {
      "type": "object",
      "required": ["id","mode","opcode","params","spriteName","value","width","height","x","y","visible"],
      "properties": {
        "id":          { "type": "string" },
        "mode":        { "type": "string", "enum": ["default","large","slider","list"] },
        "opcode":      { "type": "string" },
        "params":      { "type": "object" },
        "spriteName":  { "type": ["string","null"] },
        "value":       {},
        "width":       { "type": "number" },
        "height":      { "type": "number" },
        "x":           { "type": "number" },
        "y":           { "type": "number" },
        "visible":     { "type": "boolean" },
        "sliderMin":   { "type": "number" },
        "sliderMax":   { "type": "number" },
        "isDiscrete":  { "type": "boolean" }
      }
    }
  }
}
